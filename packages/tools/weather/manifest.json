{
  "id": "weather",
  "nameKey": "tool.weather.name",
  "descriptionKey": "tool.weather.description",
  "version": "1.0.0",
  "minAppVersion": "0.1.0",
  "permissions": ["network"],
  "privacy": {
    "level": "yellow",
    "network": [
      { "host": "geocoding-api.open-meteo.com", "dataKey": "tool.weather.privacy.geo" },
      { "host": "api.open-meteo.com", "dataKey": "tool.weather.privacy.forecast" }
    ],
    "summaryKey": "tool.weather.privacy.summary"
  },
  "widgets": [
    {
      "id": "main",
      "defaultSize": { "w": 4, "h": 4 },
      "minSize": { "w": 2, "h": 2 },
      "variants": []
    }
  ],
  "commands": ["weather.refresh"],
  "selfTests": [
    { "id": "cache-roundtrip", "titleKey": "tool.weather.test.cacheRoundtrip" },
    { "id": "wmo-mapping", "titleKey": "tool.weather.test.wmoMapping" },
    { "id": "url-building", "titleKey": "tool.weather.test.urlBuilding" }
  ],
  "tourSteps": [
    {
      "anchor": "widget:weather:main",
      "titleKey": "tool.weather.tour.title",
      "bodyKey": "tool.weather.tour.body"
    }
  ]
}

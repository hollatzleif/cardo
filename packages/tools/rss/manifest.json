{
  "id": "rss",
  "nameKey": "tool.rss.name",
  "descriptionKey": "tool.rss.description",
  "version": "1.0.0",
  "minAppVersion": "0.1.0",
  "permissions": [
    "network"
  ],
  "privacy": {
    "level": "yellow",
    "network": [
      {
        "host": "user-configured-feeds",
        "dataKey": "tool.rss.privacy.feeds"
      }
    ],
    "summaryKey": "tool.rss.privacy.summary"
  },
  "widgets": [
    {
      "id": "main",
      "defaultSize": {
        "w": 4,
        "h": 4
      },
      "minSize": {
        "w": 2,
        "h": 2
      },
      "variants": [
        "list",
        "cards",
        "headlines"
      ]
    }
  ],
  "commands": [
    "rss.refresh",
    "rss.add-feed",
    "rss.mark-read",
    "rss.context"
  ],
  "selfTests": [
    {
      "id": "parser",
      "titleKey": "tool.rss.test.parser"
    },
    {
      "id": "crud",
      "titleKey": "tool.rss.test.crud"
    },
    {
      "id": "render",
      "titleKey": "tool.rss.test.render"
    }
  ],
  "tourSteps": [
    {
      "anchor": "widget:rss:main",
      "titleKey": "tool.rss.tour.title",
      "bodyKey": "tool.rss.tour.body"
    }
  ],
  "setupSteps": []
}

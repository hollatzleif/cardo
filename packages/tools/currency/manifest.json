{
  "id": "currency",
  "nameKey": "tool.currency.name",
  "descriptionKey": "tool.currency.description",
  "version": "1.0.0",
  "minAppVersion": "0.1.0",
  "permissions": [
    "network"
  ],
  "privacy": {
    "level": "yellow",
    "network": [
      {
        "host": "open.er-api.com",
        "dataKey": "tool.currency.privacy.rates"
      }
    ],
    "summaryKey": "tool.currency.privacy.summary"
  },
  "widgets": [
    {
      "id": "main",
      "defaultSize": {
        "w": 4,
        "h": 3
      },
      "minSize": {
        "w": 2,
        "h": 2
      },
      "variants": [
        "converter",
        "rate-board",
        "single-pair"
      ]
    }
  ],
  "commands": [
    "currency.convert",
    "currency.refresh",
    "currency.context"
  ],
  "selfTests": [
    {
      "id": "convert-math",
      "titleKey": "tool.currency.test.convertMath"
    },
    {
      "id": "cache-roundtrip",
      "titleKey": "tool.currency.test.cacheRoundtrip"
    },
    {
      "id": "render",
      "titleKey": "tool.currency.test.render"
    }
  ],
  "tourSteps": [
    {
      "anchor": "widget:currency:main",
      "titleKey": "tool.currency.tour.title",
      "bodyKey": "tool.currency.tour.body"
    }
  ],
  "setupSteps": []
}

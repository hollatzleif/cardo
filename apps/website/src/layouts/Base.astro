---
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Cardo – your pivot point. A freely arrangeable dashboard that gathers everything in one calm place. Local-first, free, no account.',
} = Astro.props;
import { FORUM_URL, PUBLIC_REPO_URL, withBase } from '../lib/site';

const nav = [
  { href: withBase('/'), label: 'Home' },
  { href: withBase('/download'), label: 'Download' },
  { href: withBase('/docs'), label: 'Docs' },
  { href: withBase('/docs/tutorial'), label: 'Tutorial' },
  { href: withBase('/assistant'), label: 'Your Assistant' },
  { href: FORUM_URL, label: 'Forum', external: true },
  { href: withBase('/polls'), label: 'Polls' },
  { href: withBase('/donate'), label: 'Donate' },
];
const current = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Cardo</title>
    <meta name="description" content={description} />
    {/* Defense in depth: GitHub Pages cannot set headers, so the CSP ships as a meta tag.
        'unsafe-inline' is needed for the pages' small inline scripts (copy button, polls, admin). */}
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://cardo-polls.hollatzleif.workers.dev; frame-src 'none'; object-src 'none'; base-uri 'self'"
    />
    {/* Same icon as the desktop app, so browser tabs match the dock. */}
    <link rel="icon" type="image/png" href={withBase('/favicon.png')} />
    <link rel="icon" type="image/x-icon" href={withBase('/favicon.ico')} sizes="any" />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase('/')}>⊕ Cardo</a>
      <nav>
        {nav.map((item) => (
          <a
            href={item.href}
            rel={item.external ? 'noopener' : undefined}
            class={!item.external && (current === item.href || current === item.href + '/') ? 'active' : ''}
          >{item.label}{item.external ? ' ↗' : ''}</a>
        ))}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        Cardo is local-first: your data stays on your device. No account, no tracking –
        this website sets no cookies either.
      </p>
      <p>
        <a href={PUBLIC_REPO_URL} rel="noopener">GitHub</a> ·
        <a href={FORUM_URL} rel="noopener">Forum</a> ·
        <a href={withBase('/privacy')}>Privacy</a>
      </p>
    </footer>
    <style is:global>
      :root {
        --base: #1e1e2e;
        --surface-0: #313244;
        --surface-1: #45475a;
        --text: #cdd6f4;
        --text-muted: #a6adc8;
        --accent: #89b4fa;
        --success: #a6e3a1;
        --warning: #f9e2af;
        --danger: #f38ba8;
        --radius: 12px;
      }
      @media (prefers-color-scheme: light) {
        :root {
          --base: #eff1f5;
          --surface-0: #e6e9ef;
          --surface-1: #ccd0da;
          --text: #4c4f69;
          --text-muted: #6c6f85;
          --accent: #1e66f5;
          --success: #40a02b;
          --warning: #df8e1d;
          --danger: #d20f39;
        }
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--base);
        color: var(--text);
        line-height: 1.6;
      }
      a { color: var(--accent); }
      main { max-width: 900px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
      .site-header {
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap;
        gap: 0.5rem; padding: 0.9rem 1.25rem; border-bottom: 1px solid var(--surface-1);
        position: sticky; top: 0; background: var(--base); z-index: 10;
      }
      .brand { font-weight: 800; text-decoration: none; font-size: 1.15rem; }
      .site-header nav { display: flex; gap: 0.25rem; flex-wrap: wrap; }
      .site-header nav a {
        text-decoration: none; color: var(--text-muted); padding: 0.35rem 0.7rem; border-radius: 8px;
      }
      .site-header nav a.active, .site-header nav a:hover { color: var(--text); background: var(--surface-0); }
      .site-footer {
        border-top: 1px solid var(--surface-1); padding: 1.5rem 1.25rem; color: var(--text-muted);
        font-size: 0.9rem; text-align: center;
      }
      .card {
        background: var(--surface-0); border: 1px solid var(--surface-1);
        border-radius: var(--radius); padding: 1.25rem;
      }
      .btn {
        display: inline-block; background: var(--accent); color: var(--base);
        padding: 0.6rem 1.2rem; border-radius: 10px; text-decoration: none; font-weight: 700;
        border: none; cursor: pointer; font-size: 1rem;
      }
      .btn--ghost { background: transparent; color: var(--accent); border: 1px solid var(--accent); }
      .muted { color: var(--text-muted); }
      code, pre { font-family: ui-monospace, 'SF Mono', Menlo, monospace; }
      pre {
        background: var(--surface-0); border: 1px solid var(--surface-1); border-radius: 10px;
        padding: 0.9rem 1rem; overflow-x: auto;
      }
      kbd {
        font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.85em;
        background: var(--surface-0); border: 1px solid var(--surface-1); border-bottom-width: 2px;
        border-radius: 6px; padding: 0.1em 0.45em;
      }
      h1, h2, h3 { line-height: 1.25; }
      .badge {
        display: inline-block; padding: 0.1rem 0.6rem; border-radius: 999px; font-size: 0.8rem;
        border: 1px solid var(--success); color: var(--success);
      }
    </style>
  </body>
</html>

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cardo",
  "version": "0.1.0",
  "identifier": "app.cardo.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @cardo/desktop dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @cardo/desktop build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cardo",
        "width": 1280,
        "height": 840,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
